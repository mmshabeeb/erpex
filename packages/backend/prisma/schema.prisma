// ============================================================
// ERPEX — Prisma Schema (Multi-Tenant ERP with Auth)
// Super Admin Portal + Company Isolation + India Localization
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
// PLATFORM: SUPER ADMIN & MULTI-TENANCY
// ═══════════════════════════════════════════════════════════════

model SuperAdmin {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("super_admins")
}

model SubscriptionPlan {
  id             String   @id @default(uuid())
  name           String   @unique // FREE, PROFESSIONAL, ENTERPRISE
  displayName    String   @map("display_name")
  maxUsers       Int      @default(1) @map("max_users")
  maxBranches    Int      @default(1) @map("max_branches")
  maxItems       Int      @default(100) @map("max_items")
  monthlyPrice   Float    @default(0) @map("monthly_price")
  yearlyPrice    Float    @default(0) @map("yearly_price")
  features       String?  // JSON: enabled module flags
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  subscriptions CompanySubscription[]

  @@map("subscription_plans")
}

model Company {
  id               String   @id @default(uuid())
  name             String
  legalName        String?  @map("legal_name")
  slug             String   @unique // URL-friendly company identifier
  industry         String?
  registrationNo   String?  @map("registration_no")
  
  // Address
  addressLine1     String?  @map("address_line1")
  addressLine2     String?  @map("address_line2")
  city             String?
  state            String?
  postalCode       String?  @map("postal_code")
  country          String   @default("India")
  
  // Tax & Fiscal
  pan              String?  // PAN number (India)
  gstin            String?  // Primary GSTIN
  stateCode        String?  @map("state_code") // 2-digit census state code
  currency         String   @default("INR")
  currencySymbol   String   @default("₹") @map("currency_symbol")
  numberFormat     String   @default("INDIAN") @map("number_format") // INDIAN, INTERNATIONAL
  fiscalYearStart  Int      @default(4) @map("fiscal_year_start") // Month number (4 = April)
  
  // E-Invoice settings
  annualTurnover   Float?   @map("annual_turnover")
  eInvoiceEnabled  Boolean  @default(false) @map("e_invoice_enabled")
  
  phone            String?
  email            String?
  website          String?
  logoUrl          String?  @map("logo_url")
  
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  users              User[]
  subscriptions      CompanySubscription[]
  branches           Branch[]
  accounts           Account[]
  journalEntries     JournalEntry[]
  contacts           Contact[]
  items              Item[]
  itemGroups         ItemGroup[]
  inventoryMovements InventoryMovement[]
  priceLists         PriceList[]
  estimates          Estimate[]
  salesOrders        SalesOrder[]
  invoices           Invoice[]
  paymentsReceived   PaymentReceived[]
  creditNotes        CreditNote[]
  purchaseOrders     PurchaseOrder[]
  bills              Bill[]
  expenses           Expense[]
  paymentsMade       PaymentMade[]
  vendorCredits      VendorCredit[]
  projects           Project[]
  timesheets         Timesheet[]
  fiscalYears        FiscalYear[]
  budgets            Budget[]
  taxConfigs         TaxConfig[]
  bankStatements     BankStatement[]
  workflowRules      WorkflowRule[]
  notifications      Notification[]
  auditLogs          AuditLog[]
  gstConfigs         GSTConfig[]
  tdsSections        TDSSection[]

  @@map("companies")
}

model CompanySubscription {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  planId    String   @map("plan_id")
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])
  status    String   @default("ACTIVE") // ACTIVE, EXPIRED, CANCELLED
  startDate DateTime @map("start_date")
  endDate   DateTime? @map("end_date")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([companyId])
  @@map("company_subscriptions")
}

model User {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name         String
  email        String
  passwordHash String   @map("password_hash")
  role         String   @default("VIEWER") // OWNER, ADMIN, ACCOUNTANT, SALES, PURCHASE, VIEWER
  phone        String?
  isActive     Boolean  @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sessions Session[]

  @@unique([companyId, email])
  @@index([companyId])
  @@map("users")
}

model Session {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("sessions")
}

// ═══════════════════════════════════════════════════════════════
// INDIA LOCALIZATION: GST & TDS
// ═══════════════════════════════════════════════════════════════

model GSTConfig {
  id                    String  @id @default(uuid())
  companyId             String  @map("company_id")
  company               Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  outputCGSTAccountId   String? @map("output_cgst_account_id")
  outputSGSTAccountId   String? @map("output_sgst_account_id")
  outputIGSTAccountId   String? @map("output_igst_account_id")
  inputCGSTAccountId    String? @map("input_cgst_account_id")
  inputSGSTAccountId    String? @map("input_sgst_account_id")
  inputIGSTAccountId    String? @map("input_igst_account_id")
  rcmLiabilityAccountId String? @map("rcm_liability_account_id")
  rcmCreditAccountId    String? @map("rcm_credit_account_id")
  createdAt             DateTime @default(now()) @map("created_at")

  @@unique([companyId])
  @@map("gst_configs")
}

model TDSSection {
  id          String  @id @default(uuid())
  companyId   String  @map("company_id")
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  section     String  // e.g., "194C", "194J"
  description String
  rate        Float   // TDS rate %
  threshold   Float   @default(0) // Threshold limit
  isActive    Boolean @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([companyId])
  @@map("tds_sections")
}

// ═══════════════════════════════════════════════════════════════
// MODULE 1: CORE ACCOUNTING & GENERAL LEDGER
// ═══════════════════════════════════════════════════════════════

model Branch {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  code      String
  address   String?
  phone     String?
  gstin     String?  // Branch-specific GSTIN
  stateCode String?  @map("state_code")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  accounts       Account[]
  journalEntries JournalEntry[]
  contacts       Contact[]
  invoices       Invoice[]
  bills          Bill[]
  projects       Project[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("branches")
}

model Account {
  id           String  @id @default(uuid())
  companyId    String  @map("company_id")
  company      Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code         String
  name         String
  type         String  // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  parentId     String? @map("parent_id")
  parent       Account?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children     Account[] @relation("AccountHierarchy")
  isActive     Boolean @default(true) @map("is_active")
  isCashOrBank Boolean @default(false) @map("is_cash_or_bank")
  isSystemAccount Boolean @default(false) @map("is_system_account") // Cannot be deleted
  description  String?
  branchId     String? @map("branch_id")
  branch       Branch? @relation(fields: [branchId], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  journalItems    JournalItem[]
  taxConfigs      TaxConfig[]      @relation("TaxAccount")
  budgets         Budget[]
  expenses        Expense[]
  itemPurchaseAcct Item[]          @relation("PurchaseAccount")
  itemSalesAcct    Item[]          @relation("SalesAccount")
  itemCogsAcct     Item[]          @relation("CogsAccount")
  itemInventoryAcct Item[]         @relation("InventoryAccount")

  @@unique([companyId, code])
  @@index([companyId])
  @@index([type])
  @@index([parentId])
  @@index([branchId])
  @@map("accounts")
}

model JournalEntry {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  voucherNo    String   @map("voucher_no")
  date         DateTime
  type         String   // JOURNAL, CONTRA, PAYMENT, RECEIPT, SALES, PURCHASE
  status       String   @default("DRAFT") // DRAFT, POSTED
  narration    String?
  currencyCode String   @default("INR") @map("currency_code")
  exchangeRate Float    @default(1.0) @map("exchange_rate")
  fiscalYearId String?  @map("fiscal_year_id")
  fiscalYear   FiscalYear? @relation(fields: [fiscalYearId], references: [id])
  branchId     String?  @map("branch_id")
  branch       Branch?  @relation(fields: [branchId], references: [id])
  rectifiesId  String?  @map("rectifies_id")
  rectifies    JournalEntry?  @relation("Rectification", fields: [rectifiesId], references: [id])
  rectifiedBy  JournalEntry[] @relation("Rectification")
  createdBy    String?  @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")

  // Source document references
  invoiceId    String?  @map("invoice_id")
  billId       String?  @map("bill_id")

  items     JournalItem[]
  auditLogs AuditLog[]

  @@unique([companyId, voucherNo])
  @@index([companyId])
  @@index([date])
  @@index([type])
  @@index([status])
  @@index([fiscalYearId])
  @@index([branchId])
  @@map("journal_entries")
}

model JournalItem {
  id             String       @id @default(uuid())
  journalEntryId String       @map("journal_entry_id")
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String       @map("account_id")
  account        Account      @relation(fields: [accountId], references: [id])
  debit          Float        @default(0)
  credit         Float        @default(0)
  narration      String?
  taxConfigId    String?      @map("tax_config_id")
  taxConfig      TaxConfig?   @relation(fields: [taxConfigId], references: [id])
  createdAt      DateTime     @default(now()) @map("created_at")

  bankStatementMatches BankStatementLine[]

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_items")
}

model FiscalYear {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  isClosed  Boolean  @default(false) @map("is_closed")
  createdAt DateTime @default(now()) @map("created_at")

  periods        FiscalPeriod[]
  journalEntries JournalEntry[]
  budgets        Budget[]

  @@index([companyId])
  @@map("fiscal_years")
}

model FiscalPeriod {
  id           String     @id @default(uuid())
  fiscalYearId String     @map("fiscal_year_id")
  fiscalYear   FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  month        Int
  year         Int
  startDate    DateTime   @map("start_date")
  endDate      DateTime   @map("end_date")
  isLocked     Boolean    @default(false) @map("is_locked")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([fiscalYearId, month, year])
  @@map("fiscal_periods")
}

model Budget {
  id           String     @id @default(uuid())
  companyId    String     @map("company_id")
  company      Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name         String
  fiscalYearId String     @map("fiscal_year_id")
  fiscalYear   FiscalYear @relation(fields: [fiscalYearId], references: [id])
  accountId    String     @map("account_id")
  account      Account    @relation(fields: [accountId], references: [id])
  month        Int
  year         Int
  amount       Float      @default(0)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@unique([companyId, fiscalYearId, accountId, month, year])
  @@index([companyId])
  @@index([fiscalYearId])
  @@index([accountId])
  @@map("budgets")
}

model CurrencyRevaluation {
  id             String   @id @default(uuid())
  date           DateTime
  fromCurrency   String   @map("from_currency")
  toCurrency     String   @default("INR") @map("to_currency")
  oldRate        Float    @map("old_rate")
  newRate        Float    @map("new_rate")
  unrealizedGain Float    @map("unrealized_gain")
  journalEntryId String?  @map("journal_entry_id")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("currency_revaluations")
}

// ═══════════════════════════════════════════════════════════════
// MODULE 2: ITEMS & INVENTORY
// ═══════════════════════════════════════════════════════════════

model ItemGroup {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  description String?
  parentId    String?  @map("parent_id")
  parent      ItemGroup?  @relation("ItemGroupHierarchy", fields: [parentId], references: [id])
  children    ItemGroup[] @relation("ItemGroupHierarchy")
  createdAt   DateTime @default(now()) @map("created_at")

  items Item[]

  @@index([companyId])
  @@map("item_groups")
}

model Item {
  id                 String    @id @default(uuid())
  companyId          String    @map("company_id")
  company            Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name               String
  sku                String
  type               String    // PRODUCT, SERVICE, DIGITAL
  description        String?
  unit               String    @default("pcs") // UOM: pcs, kg, hrs, etc.
  barcode            String?
  hsnCode            String?   @map("hsn_code") // HSN for goods (India)
  sacCode            String?   @map("sac_code") // SAC for services (India)
  groupId            String?   @map("group_id")
  group              ItemGroup? @relation(fields: [groupId], references: [id])
  purchasePrice      Float     @default(0) @map("purchase_price")
  sellingPrice       Float     @default(0) @map("selling_price")
  taxConfigId        String?   @map("tax_config_id")
  purchaseAccountId  String?   @map("purchase_account_id")
  purchaseAccount    Account?  @relation("PurchaseAccount", fields: [purchaseAccountId], references: [id])
  salesAccountId     String?   @map("sales_account_id")
  salesAccount       Account?  @relation("SalesAccount", fields: [salesAccountId], references: [id])
  cogsAccountId      String?   @map("cogs_account_id")
  cogsAccount        Account?  @relation("CogsAccount", fields: [cogsAccountId], references: [id])
  inventoryAccountId String?   @map("inventory_account_id")
  inventoryAccount   Account?  @relation("InventoryAccount", fields: [inventoryAccountId], references: [id])
  reorderLevel       Int       @default(0) @map("reorder_level")
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  inventoryMovements InventoryMovement[]
  estimateLines      EstimateLine[]
  salesOrderLines    SalesOrderLine[]
  invoiceLines       InvoiceLine[]
  purchaseOrderLines PurchaseOrderLine[]
  billLines          BillLine[]
  creditNoteLines    CreditNoteLine[]
  vendorCreditLines  VendorCreditLine[]
  priceListItems     PriceListItem[]

  @@unique([companyId, sku])
  @@index([companyId])
  @@index([type])
  @@index([groupId])
  @@map("items")
}

model InventoryMovement {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  itemId    String   @map("item_id")
  item      Item     @relation(fields: [itemId], references: [id])
  date      DateTime
  type      String   // IN, OUT, ADJUST
  qty       Float
  unitCost  Float    @map("unit_cost")
  totalCost Float    @map("total_cost")
  reference String?
  sourceType String? @map("source_type")
  sourceId  String?  @map("source_id")
  remainingQty Float @default(0) @map("remaining_qty")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([companyId])
  @@index([itemId])
  @@index([date])
  @@index([type])
  @@map("inventory_movements")
}

model PriceList {
  id            String    @id @default(uuid())
  companyId     String    @map("company_id")
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  currencyCode  String    @default("INR") @map("currency_code")
  isPercentage  Boolean   @default(false) @map("is_percentage")
  roundTo       Float?    @map("round_to")
  effectiveFrom DateTime? @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")

  items    PriceListItem[]
  contacts Contact[]

  @@index([companyId])
  @@map("price_lists")
}

model PriceListItem {
  id          String    @id @default(uuid())
  priceListId String    @map("price_list_id")
  priceList   PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  itemId      String    @map("item_id")
  item        Item      @relation(fields: [itemId], references: [id])
  rate        Float
  minQty      Float     @default(1) @map("min_qty")

  @@unique([priceListId, itemId, minQty])
  @@map("price_list_items")
}

// ═══════════════════════════════════════════════════════════════
// MODULE 3: CONTACTS (Shared Sales & Purchases)
// ═══════════════════════════════════════════════════════════════

model Contact {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name            String
  type            String   // CUSTOMER, VENDOR, BOTH
  email           String?
  phone           String?
  companyName     String?  @map("company_name")
  taxId           String?  @map("tax_id") // GSTIN
  gstin           String?  // Separate GSTIN field for India validation
  pan             String?  // PAN number
  stateCode       String?  @map("state_code") // For GST state determination
  creditTermDays  Int      @default(30) @map("credit_term_days")
  creditLimit     Float?   @map("credit_limit")
  priceListId     String?  @map("price_list_id")
  priceList       PriceList? @relation(fields: [priceListId], references: [id])
  branchId        String?  @map("branch_id")
  branch          Branch?  @relation(fields: [branchId], references: [id])
  notes           String?
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  addresses       ContactAddress[]
  estimates       Estimate[]
  salesOrders     SalesOrder[]
  invoices        Invoice[]
  paymentsReceived PaymentReceived[]
  creditNotes     CreditNote[]
  purchaseOrders  PurchaseOrder[]
  bills           Bill[]
  paymentsMade    PaymentMade[]
  vendorCredits   VendorCredit[]
  expenses        Expense[]
  projects        Project[]

  @@index([companyId])
  @@index([type])
  @@index([branchId])
  @@map("contacts")
}

model ContactAddress {
  id        String  @id @default(uuid())
  contactId String  @map("contact_id")
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  type      String  // BILLING, SHIPPING
  line1     String
  line2     String?
  city      String
  state     String?
  postalCode String? @map("postal_code")
  country   String  @default("India")

  @@map("contact_addresses")
}

// ═══════════════════════════════════════════════════════════════
// MODULE 4: SALES & ACCOUNTS RECEIVABLE
// ═══════════════════════════════════════════════════════════════

model Estimate {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  number      String
  contactId   String   @map("contact_id")
  contact     Contact  @relation(fields: [contactId], references: [id])
  date        DateTime
  expiryDate  DateTime? @map("expiry_date")
  status      String   @default("DRAFT")
  subtotal    Float    @default(0)
  taxTotal    Float    @default(0) @map("tax_total")
  discount    Float    @default(0)
  total       Float    @default(0)
  notes       String?
  termsConditions String? @map("terms_conditions")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  lines       EstimateLine[]
  salesOrders SalesOrder[]
  invoices    Invoice[]

  @@unique([companyId, number])
  @@index([companyId])
  @@index([contactId])
  @@index([status])
  @@map("estimates")
}

model EstimateLine {
  id          String   @id @default(uuid())
  estimateId  String   @map("estimate_id")
  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  itemId      String?  @map("item_id")
  item        Item?    @relation(fields: [itemId], references: [id])
  description String
  qty         Float    @default(1)
  rate        Float    @default(0)
  taxConfigId String?  @map("tax_config_id")
  taxAmount   Float    @default(0) @map("tax_amount")
  amount      Float    @default(0)
  sortOrder   Int      @default(0) @map("sort_order")

  @@index([estimateId])
  @@map("estimate_lines")
}

model SalesOrder {
  id               String   @id @default(uuid())
  companyId        String   @map("company_id")
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  number           String
  contactId        String   @map("contact_id")
  contact          Contact  @relation(fields: [contactId], references: [id])
  estimateId       String?  @map("estimate_id")
  estimate         Estimate? @relation(fields: [estimateId], references: [id])
  date             DateTime
  expectedShipDate DateTime? @map("expected_ship_date")
  status           String   @default("DRAFT")
  subtotal         Float    @default(0)
  taxTotal         Float    @default(0) @map("tax_total")
  discount         Float    @default(0)
  total            Float    @default(0)
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  lines    SalesOrderLine[]
  invoices Invoice[]

  @@unique([companyId, number])
  @@index([companyId])
  @@index([contactId])
  @@index([status])
  @@map("sales_orders")
}

model SalesOrderLine {
  id           String     @id @default(uuid())
  salesOrderId String     @map("sales_order_id")
